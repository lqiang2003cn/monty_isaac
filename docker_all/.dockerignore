# shared/ is mounted at runtime via docker-compose volumes — generally not COPYd into images.
# Exceptions: meshes are needed at build time; init_positions.yaml is baked in as fallback.
shared/
!shared/x3plus_isaac/meshes/
!shared/x3plus_config/

# Utility scripts not needed inside containers
scripts/

# Component template skeleton
components/_template/

# tbp.monty submodule: only needed by monty_comp — allow COPY but exclude
# heavy non-essential dirs to speed up build context transfer.
third_party/tbp.monty/.git
third_party/tbp.monty/tests
third_party/tbp.monty/docs
third_party/tbp.monty/benchmarks
third_party/tbp.monty/rfcs
third_party/tbp.monty/tools
third_party/tbp.monty/.github
third_party/tbp.monty/.vale

# Docker and compose files themselves
**/Dockerfile
**/.dockerignore
**/docker-compose*.yml

# Version control
**/.git
**/.gitignore
**/.gitkeep

# IDE / editor
**/.vscode
**/.idea
**/*.swp
**/*.swo
**/*~

# Python caches
**/__pycache__
**/*.pyc
**/*.pyo

# colcon build artifacts (should not leak into build context)
**/build/
**/install/
**/log/
**/.colcon
